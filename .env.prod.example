# Скопировать на VPS: cp .env.prod.example .env
# Пароль Postgres — только буквы/цифры (без @ : / #), иначе сломается DATABASE_URL

# --- Домен и HTTPS (Caddy + Let's Encrypt) ---
DOMAIN=club.example.com
ACME_EMAIL=admin@example.com

# --- PostgreSQL (внутри Docker) ---
POSTGRES_USER=bgclub
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=bgclub

# DATABASE_URL на VPS не обязателен — compose подставит из POSTGRES_*.
# Нужен, если запускаете API/бот вне compose:
# DATABASE_URL=postgresql+asyncpg://bgclub:PASSWORD@postgres:5432/bgclub
# REDIS_URL=redis://redis:6379/0

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=your_club_bot

# HTTPS-URL Mini App (тот же домен, что DOMAIN)
MINIAPP_URL=https://club.example.com
CORS_ORIGINS=https://club.example.com

# --- Безопасность ---
SECRET_KEY=generate-long-random-string-here
ADMIN_TELEGRAM_IDS=123456789

# В проде обязательно false — авторизация только через Telegram initData
DEV_AUTH_ENABLED=false

# --- Опционально ---
SESSION_REMINDER_HOURS=1
BGG_TOKEN=
