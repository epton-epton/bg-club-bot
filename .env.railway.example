# Справочник переменных для Railway (значения задаются в панели, не в файле)
# Полная инструкция: docs/deploy-railway.md

# --- После деплоя API (публичный URL) ---
# VITE_API_URL=https://ВАШ-API.up.railway.app
#   ↑ только сервис miniapp, включить «Available at Build Time»

# --- После деплоя miniapp (публичный URL) ---
# MINIAPP_URL=https://ВАШ-MINIAPP.up.railway.app
# CORS_ORIGINS=https://ВАШ-MINIAPP.up.railway.app

# --- Из плагинов Railway (Reference Variables) ---
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}

# --- Общие (api + bot) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=your_club_bot
# SECRET_KEY=        # openssl rand -hex 32
# ADMIN_TELEGRAM_IDS=123456789
# DEV_AUTH_ENABLED=false
# SESSION_REMINDER_HOURS=1
# BGG_TOKEN=         # опционально

# --- Только API ---
# UPLOAD_DIR=/app/data/uploads
