# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Mini App URL (HTTPS в проде; для локальной разработки: http://localhost:5173)
MINIAPP_URL=http://localhost:5173

# CORS для Mini App (через запятую)
CORS_ORIGINS=http://localhost:5173

# Database (localhost — вне Docker; в compose подставляется postgres:5432)
DATABASE_URL=postgresql+asyncpg://bgclub:bgclub@localhost:5432/bgclub

# Redis (localhost — вне Docker; в compose подставляется redis:6379)
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=change-me
ADMIN_TELEGRAM_IDS=123456789

# Локальная разработка в браузере (без Telegram initData). В проде — false!
DEV_AUTH_ENABLED=true
DEV_TELEGRAM_ID=999999001

# Notifications
SESSION_REMINDER_HOURS=1

# BoardGameGeek XML API (нужен для импорта игр; регистрация: boardgamegeek.com/applications)
BGG_TOKEN=
